<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="cibei.mapper.RantMapper">

    <resultMap id="RantResultMap" type="cibei.entity.Rant">
        <id     property="id"         column="id"/>
        <result property="content"    column="content"/>
        <result property="voiceUrl"   column="voice_url"/>
        <result property="imageUrl"   column="image_url"/>
        <result property="createdAt"  column="created_at"/>
        <result property="ipLocation" column="ip_location"/>
    </resultMap>

    <!-- 新增吐槽 -->
    <insert id="insert" parameterType="cibei.entity.Rant">
        INSERT INTO rants (id, content, voice_url, image_url, created_at, ip_location)
        VALUES (#{id}, #{content}, #{voiceUrl}, #{imageUrl}, #{createdAt}, #{ipLocation})
    </insert>

    <!-- 根据ID查询 -->
    <select id="selectById" parameterType="String" resultMap="RantResultMap">
        SELECT * FROM rants WHERE id = #{id}
    </select>

    <!-- 查询最新吐槽（分页） -->
    <select id="selectLatest" resultMap="RantResultMap">
        SELECT * FROM rants ORDER BY created_at DESC LIMIT #{offset}, #{limit}
    </select>

    <!-- 统计总数 -->
    <select id="count" resultType="int">
        SELECT COUNT(*) FROM rants
    </select>

    <!-- 根据ID删除 -->
    <delete id="deleteById" parameterType="String">
        DELETE FROM rants WHERE id = #{id}
    </delete>

</mapper>
